{
  "rules": {
    "leaderboard": {
      ".read": true,
      "$uid": {
        ".write": true,
        ".validate": "newData.hasChildren(['uid', 'username', 'xp', 'timestamp'])",
        "uid": { ".validate": "newData.isString() && newData.val().length < 100" },
        "username": { ".validate": "newData.isString() && newData.val().length < 60" },
        "xp": { ".validate": "newData.isNumber()" },
        "timestamp": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },
    "reports": {
      ".read": true,
      "$reportId": {
        ".write": true,
        "$other": { ".validate": true }
      }
    }
  }
}
